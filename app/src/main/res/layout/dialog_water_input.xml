<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface_white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="add water intake"
        android:fontFamily="@font/convergence"
        android:textSize="18sp"
        android:textColor="@color/dark_green"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="amount (ml)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_water_ml"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_water_goal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="goal: 2000 ml/day"
        android:fontFamily="@font/convergence"
        android:textSize="12sp"
        android:textColor="@color/dark_green"
        android:alpha="0.7"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_water_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="add"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/dark_green"
        app:cornerRadius="12dp"/>
</LinearLayout>
