<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_forkitleaf_tabs"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Fork it"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/antic_didone"
                android:textColor="@color/dark_green"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="back"/>
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_meal_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"/>

                    <TextView
                        android:id="@+id/tv_meal_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tv_meal_ingredients"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="13sp"
                        android:textColor="@color/dark_green"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nutrition"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tv_meal_kcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"/>

                    <TextView
                        android:id="@+id/tv_meal_macros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:id="@+id/tv_portion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="11sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/iv_meal_result"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
