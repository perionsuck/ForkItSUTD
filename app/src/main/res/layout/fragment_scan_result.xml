<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_forkitleaf_tabs"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Fork it"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/antic_didone"
                android:textColor="@color/dark_green"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="back"/>
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/et_meal_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"
                        android:background="@android:color/transparent"
                        android:inputType="textCapSentences"
                        android:hint="Meal name"/>

                    <EditText
                        android:id="@+id/et_meal_ingredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="13sp"
                        android:textColor="@color/dark_green"
                        android:alpha="0.9"
                        android:layout_marginTop="4dp"
                        android:background="@android:color/transparent"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:gravity="top|start"
                        android:hint="Ingredients"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nutrition (tap to edit)"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Calories"
                            android:fontFamily="@font/convergence"
                            android:textSize="13sp"
                            android:textColor="@color/dark_green"/>
                        <EditText
                            android:id="@+id/et_meal_kcal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/convergence"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/dark_green"
                            android:background="@drawable/edittext_search_bg"
                            android:padding="8dp"
                            android:inputType="numberDecimal"
                            android:hint="kcal"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Protein (g)"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"/>
                        <EditText
                            android:id="@+id/et_protein_g"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/convergence"
                            android:textSize="14sp"
                            android:textColor="@color/dark_green"
                            android:background="@drawable/edittext_search_bg"
                            android:padding="8dp"
                            android:inputType="numberDecimal"
                            android:hint="g"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Carbs (g)"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"/>
                        <EditText
                            android:id="@+id/et_carbs_g"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/convergence"
                            android:textSize="14sp"
                            android:textColor="@color/dark_green"
                            android:background="@drawable/edittext_search_bg"
                            android:padding="8dp"
                            android:inputType="numberDecimal"
                            android:hint="g"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Fat (g)"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"/>
                        <EditText
                            android:id="@+id/et_fat_g"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/convergence"
                            android:textSize="14sp"
                            android:textColor="@color/dark_green"
                            android:background="@drawable/edittext_search_bg"
                            android:padding="8dp"
                            android:inputType="numberDecimal"
                            android:hint="g"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confidence: "
                            android:fontFamily="@font/convergence"
                            android:textSize="11sp"
                            android:textColor="@color/dark_green"/>
                        <TextView
                            android:id="@+id/tv_confidence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/convergence"
                            android:textSize="11sp"
                            android:textColor="@color/dark_green"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_green"
                            android:layout_marginStart="4dp"
                            android:contentDescription=""/>
                    </LinearLayout>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/iv_meal_result"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Portion (grams)"
                android:fontFamily="@font/convergence"
                android:textSize="13sp"
                android:textColor="@color/dark_green"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Changing grams scales nutrition from the AI estimate until you edit calories or macros."
                android:fontFamily="@font/convergence"
                android:textSize="11sp"
                android:textColor="@color/dark_green"
                android:alpha="0.75"/>
            <EditText
                android:id="@+id/et_portion_g"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/convergence"
                android:textSize="16sp"
                android:textColor="@color/dark_green"
                android:background="@drawable/edittext_search_bg"
                android:padding="12dp"
                android:inputType="number"
                android:hint="e.g. 350"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_meal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Add meal"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/surface_white"
            android:gravity="center"
            app:backgroundTint="@color/dark_green"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_ai_brain"
                    android:contentDescription=""/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="A.I detected this meal"
                    android:fontFamily="@font/convergence"
                    android:textSize="14sp"
                    android:textColor="@color/dark_green"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
