<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_forkitleaf_tabs"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fork it"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/antic_didone"
                android:textColor="@color/dark_green"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_settings_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu_hamburger"
                android:contentDescription="menu"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/profile_pic_container"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp">
                <ImageView
                    android:id="@+id/iv_profile_pic"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_outline_dark_green"
                    android:contentDescription="profile"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tv_settings_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/convergence"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"/>

                <TextView
                    android:id="@+id/tv_settings_handle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/convergence"
                    android:textSize="13sp"
                    android:textColor="@color/text_black"
                    android:alpha="0.7"/>

                <TextView
                    android:id="@+id/tv_settings_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/convergence"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_metrics_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tv_profile_age"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:background="@color/surface_soft"
                android:padding="12dp"
                android:fontFamily="@font/convergence"
                android:textSize="12sp"
                android:textColor="@color/text_black"
                android:layout_marginEnd="4dp"
                android:text="Age —" />

            <TextView
                android:id="@+id/tv_profile_height"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:background="@color/surface_soft"
                android:padding="12dp"
                android:fontFamily="@font/convergence"
                android:textSize="12sp"
                android:textColor="@color/text_black"
                android:layout_marginHorizontal="4dp"
                android:text="Height —" />

            <TextView
                android:id="@+id/tv_profile_weight"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:background="@color/surface_soft"
                android:padding="12dp"
                android:fontFamily="@font/convergence"
                android:textSize="12sp"
                android:textColor="@color/text_black"
                android:layout_marginStart="4dp"
                android:text="Weight —" />
        </LinearLayout>

        <TextView
            android:id="@+id/settings_personal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Personal details"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_fitness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Goals"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_dietary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Dietary preferences"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_saved"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Saved foods"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Progress"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_reminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Reminders &amp; Notifications"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Sync to device"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_privacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="Privacy"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/settings_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/surface_soft_alt"
            android:text="History"
            android:fontFamily="@font/convergence"
            android:textColor="@color/text_black"
            android:drawableEnd="@drawable/ic_arrow_right"/>
    </LinearLayout>
</ScrollView>
