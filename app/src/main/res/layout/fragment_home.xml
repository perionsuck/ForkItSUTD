<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_forkitleaf_tabs"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fork it"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/antic_didone"
                android:textColor="@color/dark_green"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu_hamburger"
                android:contentDescription="menu"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bg_leaf"
                android:contentDescription=""/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_cal_consumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2256"
                        android:fontFamily="@font/convergence"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="eaten"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"/>
                </LinearLayout>

                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/circle_outline_dark_green"/>

                <LinearLayout
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginStart="-140dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_cal_left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="752"
                        android:fontFamily="@font/convergence"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kcals left"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_cal_burned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="708"
                        android:fontFamily="@font/convergence"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_green"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="burned"
                        android:fontFamily="@font/convergence"
                        android:textSize="12sp"
                        android:textColor="@color/dark_green"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/btn_see_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_marginBottom="8dp">
            <ImageView
                android:id="@+id/iv_stats_arrow"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_see_stats"
                android:contentDescription=""/>
            <TextView
                android:id="@+id/tv_see_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="see stats"
                android:fontFamily="@font/convergence"
                android:textSize="13sp"
                android:textColor="@color/dark_green"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stats_collapsible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_soft"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="protein left"
                        android:fontFamily="@font/convergence"
                        android:textSize="13sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_protein"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        app:indicatorColor="@color/dark_green"
                        app:trackColor="#E8E8E8"
                        app:trackCornerRadius="4dp"/>
                    <TextView
                        android:id="@+id/tv_protein_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="11sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_soft"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="carbs left"
                        android:fontFamily="@font/convergence"
                        android:textSize="13sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_carbs"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        app:indicatorColor="@color/dark_green"
                        app:trackColor="#E8E8E8"
                        app:trackCornerRadius="4dp"/>
                    <TextView
                        android:id="@+id/tv_carbs_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="11sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_soft"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fats left"
                        android:fontFamily="@font/convergence"
                        android:textSize="13sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_fat"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        app:indicatorColor="@color/dark_green"
                        app:trackColor="#E8E8E8"
                        app:trackCornerRadius="4dp"/>
                    <TextView
                        android:id="@+id/tv_fat_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/convergence"
                        android:textSize="11sp"
                        android:textColor="@color/dark_green"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/water_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface_soft"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Water"
                            android:fontFamily="@font/convergence"
                            android:textSize="13sp"
                            android:textColor="@color/dark_green"/>
                        <TextView
                            android:id="@+id/btn_add_water"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ add"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"
                            android:padding="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        <LinearLayout android:id="@+id/col_mon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_mon" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_tue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_tue" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tu" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_wed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_wed" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_thu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_thu" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Th" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_fri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_fri" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_sat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_sat" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sa" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/col_sun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom" android:layout_marginHorizontal="2dp">
                            <View android:id="@+id/bar_sun" android:layout_width="match_parent" android:layout_height="8dp" android:background="@color/water_blue" android:minHeight="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Su" android:fontFamily="@font/convergence" android:textSize="10sp" android:textColor="@color/dark_green" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_soft"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Streak"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"
                            android:layout_marginBottom="8dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/tv_streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="23"
                                android:fontFamily="@font/convergence"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/dark_green"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_streak_flame"
                                android:layout_marginStart="4dp"
                                android:contentDescription=""/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="keep up the good work!"
                            android:fontFamily="@font/convergence"
                            android:textSize="10sp"
                            android:textColor="@color/dark_green"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_soft"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_heartbeat"
                            android:contentDescription=""/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Heart Rate"
                            android:fontFamily="@font/convergence"
                            android:textSize="12sp"
                            android:textColor="@color/dark_green"
                            android:layout_marginStart="8dp"/>
                        <TextView
                            android:id="@+id/tv_heart_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="70 BPM"
                            android:fontFamily="@font/convergence"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/dark_green"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/recommendations_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_soft"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_heart_solid"
                    android:contentDescription=""/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recommendations"
                    android:fontFamily="@font/convergence"
                    android:textSize="14sp"
                    android:textColor="@color/dark_green"
                    android:layout_marginStart="12dp"/>
                <TextView
                    android:id="@+id/tv_recommendations_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:fontFamily="@font/convergence"
                    android:textSize="13sp"
                    android:textColor="@color/dark_green"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription=""/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
