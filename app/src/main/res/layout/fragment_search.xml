<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_forkitleaf_tabs"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fork it"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/antic_didone"
                android:textColor="@color/dark_green"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_search_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu_hamburger"
                android:contentDescription="menu"/>
        </FrameLayout>

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="search food..."
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:padding="16dp"
            android:background="@drawable/edittext_search_bg"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trending / Popular"
            android:fontFamily="@font/convergence"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/dark_green"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No matches found?"
            android:fontFamily="@font/convergence"
            android:textSize="14sp"
            android:textColor="@color/dark_green"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Can't find your food? Add it manually with custom calories and macros."
            android:fontFamily="@font/convergence"
            android:textSize="12sp"
            android:textColor="@color/dark_green"
            android:alpha="0.85"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_custom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="+ Add custom food"
            android:textSize="15sp"
            android:textColor="@color/surface_white"
            app:backgroundTint="@color/dark_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</ScrollView>
