<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Personal details"
        android:fontFamily="@font/antic_didone"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/dark_green"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Handle (@username)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Age"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_age"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Height (cm)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Weight (kg)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_weight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Goal weight (kg)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/text_black"
        app:hintTextColor="@color/text_black"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_goal_weight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_black"
            android:textColorHint="@color/text_black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gender"
        android:fontFamily="@font/convergence"
        android:textSize="14sp"
        android:textColor="@color/dark_green"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"/>

    <RadioGroup
        android:id="@+id/rg_gender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <RadioButton android:id="@+id/rb_male"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Male"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
        <RadioButton android:id="@+id/rb_female"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Female"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"
            android:layout_marginStart="24dp"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activity level"
        android:fontFamily="@font/convergence"
        android:textSize="14sp"
        android:textColor="@color/dark_green"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rg_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton android:id="@+id/rb_sedentary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sedentary (little or no exercise)"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
        <RadioButton android:id="@+id/rb_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lightly active (exercise 1-3 days/week)"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
        <RadioButton android:id="@+id/rb_moderate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moderately active (exercise 3-5 days/week)"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
        <RadioButton android:id="@+id/rb_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Very active (exercise 6-7 days/week)"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
        <RadioButton android:id="@+id/rb_extra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extra active (physical job + exercise)"
            android:textColor="@color/text_black"
            android:buttonTint="@color/dark_green"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_personal"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Save"
        android:textColor="@color/text_black"
        android:textSize="15sp"
        app:backgroundTint="@color/dark_green"
        app:cornerRadius="12dp"
        android:layout_marginTop="20dp"/>
</LinearLayout>
</ScrollView>
